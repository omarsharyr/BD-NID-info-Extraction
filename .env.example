APP_ENV=development
LOG_LEVEL=INFO
MAX_UPLOAD_SIZE_MB=8
MIN_IMAGE_WIDTH=700
MIN_IMAGE_HEIGHT=450
BLUR_THRESHOLD=140
OCR_CONFIDENCE_THRESHOLD=55
TEMP_DIR=/tmp/nid-extractor
TRANSLATION_PROVIDER=local
TRANSLATION_API_URL=
TRANSLATION_API_KEY=
ENABLE_DEBUG=false
PADDLE_OCR_LANGUAGE=en
PADDLE_USE_ANGLE_CLS=true
TESSERACT_CMD=

# AI-based extraction (default)
EXTRACTION_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
GEMINI_TIMEOUT_SECONDS=45
GEMINI_MAX_RETRIES=5
